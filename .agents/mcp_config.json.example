{
  "mcpServers": {
    "github": {
      "serverURL": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer <YOUR_GITHUB_PAT>"
      }
    },
    "gitea": {
      "serverURL": "http://localhost:3000/mcp",
      "headers": {
        "Authorization": "Bearer <your personal access token>"
      }
    }
  }
}
